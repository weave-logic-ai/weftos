!.claude/skills/
.claude/skills/*
!.claude/skills/plane-workflow/
!.claude/skills/weftos-design/
.claude-flow/
.hive-mind
.swarm/
target/
.env
.env-keys.json
# Documented Vite build-time template files (no secrets) — keep tracked.
!clawft-ui/.env
!clawft-ui/.env.mock
crates/clawft-wasm/www/pkg/

# WeftOS runtime state
weave.toml
.weftos/
gui/node_modules/
gui/dist/
clawft-ui/node_modules/
clawft-ui/dist/
# WEFT-313: Tauri auto-generated capability/schema files for the dashboard shell.
clawft-ui/src-tauri/gen/
clawft-ui/src-tauri/target/
clawft-ui/src-tauri/Cargo.lock
# WEFT-314: Playwright local artefacts.
clawft-ui/test-results/
clawft-ui/playwright-report/
clawft-ui/.playwright/
.vercel
# KB: commit .gz only, decompress client-side or via CI
docs/src/public/kb/weftos-docs.rvf.json
# Build artifacts - regenerated by scripts/build-kb.sh
docs/src/public/kb/*.rvf
docs/src/public/kb/*.rvf.json
docs/src/public/kb/*.rvf.json.gz
.planning/sonobuoy/papers/pdfs/
.planning/clients/weave.toml

# WeftOS
graphify-out/

# ── Untracked-cruft guards (added during git-clean pass) ──────────────
# Node dependencies anywhere in the tree (root-level agentic-flow install,
# nested package installs, etc). Supersedes the gui/ + clawft-ui/ rules above.
node_modules/

# Local ruvector / AgentDB brain state (vector store generated by the
# claude-flow memory tools). Regenerable, machine-local — never committed.
ruvector.db
ruvector.db/

# Business-sensitive symposium material — live client-deal docs (real client
# names / contacts / NDA) and the investor pitch + business plan + market
# research (funding ask, pricing strategy) + ~12MB regenerable deck images.
# Kept on disk for reference, deliberately NOT committed. (git-clean 2026-06-28)
.planning/symposiums/krause-docs-generator/
.planning/symposiums/sonobuoy/
.planning/sonobuoy/sonar-handoff.md

# ESP-IDF embedded build toolchain (cmake/xtensa-esp-elf/python envs) —
# multi-GB, regenerable. Lands under crates/clawft-edge-pad-idf/.embuild.
.embuild/

# `ui/` holds only generated build output (node_modules/ + dist/); it has
# no tracked source. Mirror the gui/ and clawft-ui/ convention.
ui/

# Windows "downloaded from the internet" zone metadata sidecar files.
*:Zone.Identifier

# Large binary planning artifacts. The repo norm is zero tracked
# pdf/pptx/zip (decks + papers are shared out-of-band, not via git).
*.pdf
*.pptx
*.zip

# Vendor reference downloads (CrowPanel display SDK + course files) —
# multi-GB, not source. Kept on-disk for reference, never committed.
.planning/devices/crowpanel-display/CrowPanel-7.0-HMI-ESP32-Display-800x480/
.planning/devices/crowpanel-display/CrowPanel-ESP32-Display-Course-File/
