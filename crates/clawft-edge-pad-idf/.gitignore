# Cargo build artifacts
/target

# Flashable firmware images — regenerable from the ELF in target/.
/*.bin

# Stock firmware backups — opaque 4 MB blobs, too large for git.
/firmware-backups/*.bin

# WiFi credentials — never commit. Copy wifi_secrets.rs.example →
# wifi_secrets.rs and fill in. The .example template IS committed.
/src/wifi_secrets.rs

# ESP-IDF build output and sdkconfig overrides for ephemeral dev.
/sdkconfig
/sdkconfig.old
/build

# Downloaded reference material — not source.
/ref/
