# clawft-ui — default Vite env (live backend mode)
#
# These are *build-time* values inlined by Vite into the SPA bundle.
# They MUST NOT contain secrets. Anything truly sensitive (API tokens,
# provider keys) is supplied at runtime via the auth flow or, in
# browser-only mode, via the encrypted IndexedDB key store.
#
# Local overrides go in `.env.local` (gitignored).
# For mock-only dev, use `npm run dev -- --mode mock` (loads `.env.mock`).

# Base URL for the Axum gateway. Empty string -> same-origin (recommended
# in production behind a reverse proxy or the `weft ui --ui-dir` server).
VITE_API_URL=

# Base URL for the WebSocket. Empty string -> derived from VITE_API_URL,
# falling back to same-origin `/ws` over the page's ws/wss scheme.
VITE_WS_URL=

# Backend adapter selection: "axum" | "wasm" | "mock".
# Overridden by the `?mode=` URL parameter at runtime.
VITE_BACKEND_MODE=axum

# Set true to boot MSW handlers and skip real network calls. Defaults
# to false here so live dev hits the Axum gateway.
VITE_MOCK_API=false
