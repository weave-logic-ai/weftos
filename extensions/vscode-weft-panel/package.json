{
  "name": "vscode-weft-panel",
  "displayName": "WeftOS Dev Panel",
  "description": "M0 dev-panel: proves the daemon <-> extension <-> webview loop for WeftOS.",
  "version": "0.0.1",
  "publisher": "weavelogic",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:weft.openPanel",
    "onWebviewPanel:weft.panel"
  ],
  "contributes": {
    "commands": [
      {
        "command": "weft.openPanel",
        "title": "WeftOS: Open Panel",
        "category": "WeftOS"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "compile-tests": "tsc -p test/",
    "watch": "tsc -w -p .",
    "package": "vsce package --allow-missing-repository",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "node ./out-test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.0",
    "glob": "^10.3.10",
    "mocha": "^10.4.0",
    "typescript": "^5.4.0"
  }
}
